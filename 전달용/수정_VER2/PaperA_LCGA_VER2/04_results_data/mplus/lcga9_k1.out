INPUT INSTRUCTIONS

  TITLE:
    KCYPS 2018 m1 9-item depression LCGA K=1;

  DATA:
    FILE IS kcyps_dep9.dat;

  VARIABLE:
    NAMES ARE id y1 y2 y3 y4 y5 y6 y7;
    USEVARIABLES ARE y1 y2 y3 y4 y5 y6 y7;
    IDVARIABLE IS id;
    MISSING ARE ALL (-999);
    CLASSES = c(1);

  ANALYSIS:
    TYPE = MIXTURE;
    ESTIMATOR = ML;
    STARTS = 1000 250;
    STITERATIONS = 20;
    PROCESSORS = 4;

