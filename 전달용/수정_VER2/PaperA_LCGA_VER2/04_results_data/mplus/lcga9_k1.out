    %OVERALL%
      i s q | y1@-3 y2@-2 y3@-1 y4@0 y5@1 y6@2 y7@3;
      i@0;
      s@0;
      q@0;
      y1-y7 (resid);

  OUTPUT:
    TECH1 TECH4 TECH8;




