  VARIABLE:
    NAMES ARE id y1 y2 y3 y4 y5 y6 y7;
    USEVARIABLES ARE y1 y2 y3 y4 y5 y6 y7;
    IDVARIABLE IS id;
    MISSING ARE ALL (-999);
    CLASSES = c(2);

  ANALYSIS:
    TYPE = MIXTURE;
    ESTIMATOR = ML;
    STARTS = 1000 250;
    STITERATIONS = 20;
